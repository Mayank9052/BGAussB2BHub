{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch BGaussCRM.API",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build",
      "program": "${workspaceFolder}/BgaussCRM.api/bin/Debug/net8.0/BGaussCRM.API.dll",
      "args": [],
      "cwd": "${workspaceFolder}/BgaussCRM.api",
      "stopAtEntry": false,
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      },
      "serverReadyAction": {
        "action": "openExternally",
        "uriFormat": "%s/swagger"   // <-- automatically open Swagger
      },
      "justMyCode": true
    }
  ]
}